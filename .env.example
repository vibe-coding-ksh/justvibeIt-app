# ================================
# Appwrite Configuration
# ================================
# Get these from your Appwrite Console (cloud.appwrite.io)
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-project-id

# Optional: Database ID (default: "main")
# VITE_APPWRITE_DATABASE_ID=main

# Optional: Storage bucket ID (default: "images")
# VITE_APPWRITE_BUCKET_ID=images

# ================================
# Deployment Configuration
# ================================
# Set this to your GitHub Pages path before deploying
# Example: /your-repo-name/
# VITE_BASE_PATH=/
